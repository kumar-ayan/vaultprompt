# Node Environment
NODE_ENV=development
PORT=3001

# ─── Google Services (Required) ──────────────────────────────────────────────

# Gemini — Event plan generation & judging
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── Google Services (Optional — graceful fallback if missing) ────────────────

# Google Perspective API — Safety Auditing
# Get yours at: https://perspectiveapi.com
GOOGLE_PERSPECTIVE_API_KEY=your_perspective_key_here

# Google Programmable Custom Search — Real-time Event Grounding
# Get yours at: https://developers.google.com/custom-search/v1/introduction
GOOGLE_SEARCH_API_KEY=your_search_key_here
GOOGLE_SEARCH_CX=your_search_engine_id_here

# ─── Server Config ────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
SITE_NAME=EventPilot
ALLOWED_ORIGINS=http://localhost:3000
